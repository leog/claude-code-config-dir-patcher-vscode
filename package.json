{
  "name": "claude-code-config-dir-patcher",
  "displayName": "Claude Code Profiles",
  "description": "Use multiple Claude Code accounts in VS Code. Patches Anthropic's Claude Code extension so CLAUDE_CONFIG_DIR isolates auth/session storage per VS Code profile, enabling per-profile account switching.",
  "version": "0.1.9",
  "keywords": [
    "claude",
    "claude code",
    "anthropic",
    "profiles",
    "profile",
    "account",
    "accounts",
    "multi-account",
    "account switching",
    "CLAUDE_CONFIG_DIR",
    "config dir",
    "auth",
    "session",
    "isolation",
    "ai"
  ],
  "publisher": "leog",
  "license": "MIT",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#343232",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/leog/claude-code-config-dir-patcher-vscode.git"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "extensionDependencies": [
    "anthropic.claude-code"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "check-upstream": "node scripts/check-upstream-patchability.mjs",
    "verify-patch": "node scripts/check-upstream-patchability.mjs",
    "package": "npm run build && npx --yes @vscode/vsce@3.9.1 package"
  },
  "dependencies": {
    "@sentry/core": "10.52.0"
  },
  "contributes": {
    "configuration": {
      "title": "Claude Code Profiles",
      "properties": {
        "claudeConfigDirPatcher.autoPatch": {
          "type": "boolean",
          "default": true,
          "description": "Automatically patch the installed Anthropic Claude Code extension on VS Code startup."
        },
        "claudeConfigDirPatcher.showStartupNotifications": {
          "type": "boolean",
          "default": false,
          "description": "Show a notification when startup auto-patching succeeds or is already applied."
        },
        "claudeConfigDirPatcher.analytics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Allow this extension to send redacted error reports and a first-activation install event to Sentry when VS Code telemetry is also enabled.",
          "tags": [
            "telemetry",
            "usesOnlineServices"
          ]
        }
      }
    },
    "commands": [
      {
        "command": "claudeConfigDirPatcher.apply",
        "title": "Claude Code Profiles: Apply Patch"
      },
      {
        "command": "claudeConfigDirPatcher.verify",
        "title": "Claude Code Profiles: Verify Patch"
      },
      {
        "command": "claudeConfigDirPatcher.restore",
        "title": "Claude Code Profiles: Restore Backup"
      }
    ]
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
